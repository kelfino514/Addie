# Milestone 2 — set these in the Netlify dashboard (Site settings → Environment variables),
# NOT in this file and NOT in the browser. This file documents what's needed.

# Required for live Brain summarization + to-do extraction (Claude).
ANTHROPIC_API_KEY=sk-ant-...

# Required only for the "Upload audio" transcription feature (OpenAI Whisper).
# Live listen uses the browser's speech recognition and needs no key.
OPENAI_API_KEY=sk-...
